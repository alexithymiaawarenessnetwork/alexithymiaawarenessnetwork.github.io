{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Hopeful, humane, grounded public-facing design system for the Alexithymia Awareness Network; community-nonprofit warmth and quiet editorial restraint with a light layer of civic trust.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.122,
          0.141,
          0.188
        ],
        "hex": "#1f2430"
      }
    },
    "secondary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.369,
          0.4,
          0.439
        ],
        "hex": "#5e6670"
      }
    },
    "tertiary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.306,
          0.416,
          0.38
        ],
        "hex": "#4e6a61"
      }
    },
    "accent": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.604,
          0.357,
          0.271
        ],
        "hex": "#9a5b45"
      }
    },
    "neutral": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.965,
          0.945,
          0.918
        ],
        "hex": "#f6f1ea"
      }
    },
    "surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          0.992,
          0.988
        ],
        "hex": "#fffdfc"
      }
    },
    "border": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.847,
          0.808,
          0.765
        ],
        "hex": "#d8cec3"
      }
    },
    "tint-sage": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.91,
          0.937,
          0.922
        ],
        "hex": "#e8efeb"
      }
    },
    "tint-clay": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.949,
          0.898,
          0.871
        ],
        "hex": "#f2e5de"
      }
    },
    "on-primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          1,
          1
        ],
        "hex": "#ffffff"
      }
    },
    "on-tertiary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          1,
          1
        ],
        "hex": "#ffffff"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 40,
        "unit": "px"
      }
    },
    "2xl": {
      "$value": {
        "value": 64,
        "unit": "px"
      }
    },
    "3xl": {
      "$value": {
        "value": 96,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 36,
        "unit": "px"
      }
    },
    "full": {
      "$value": {
        "value": 9999,
        "unit": "px"
      }
    }
  },
  "typography": {
    "h1": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Source Serif 4",
        "fontSize": {
          "value": 3.5,
          "unit": "rem"
        },
        "fontWeight": 600,
        "letterSpacing": {
          "value": -0.02,
          "unit": "em"
        }
      }
    },
    "h2": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Source Serif 4",
        "fontSize": {
          "value": 2.5,
          "unit": "rem"
        },
        "fontWeight": 600,
        "letterSpacing": {
          "value": -0.015,
          "unit": "em"
        }
      }
    },
    "h3": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Source Serif 4",
        "fontSize": {
          "value": 1.75,
          "unit": "rem"
        },
        "fontWeight": 600
      }
    },
    "body-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 1.125,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    },
    "body-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 1,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    },
    "body-sm": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 0.9375,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    },
    "label-sm": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 0.8125,
          "unit": "rem"
        },
        "fontWeight": 600,
        "letterSpacing": {
          "value": 0.04,
          "unit": "em"
        }
      }
    },
    "eyebrow": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 0.75,
          "unit": "rem"
        },
        "fontWeight": 600,
        "letterSpacing": {
          "value": 0.08,
          "unit": "em"
        }
      }
    }
  }
}
